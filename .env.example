# ── E2B ─────────────────────────────────────────────────────────────────────
E2B_API_KEY=

# Set this after running: python e2b-template/template.py
# Leave as "base" to use the default E2B image (slower start — deps installed at runtime)
E2B_TEMPLATE_ID=base

# Idle timeout in seconds before E2B kills the sandbox. Reset on every chat message.
E2B_SANDBOX_TIMEOUT=1200

# ── Redis / Valkey ───────────────────────────────────────────────────────────
# Full TCP URL including credentials. Example: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=

# ── LLM — Modal (OSS path) ───────────────────────────────────────────────────
# Copy the web endpoint URL from `modal deploy` output (without /v1 suffix)
MODAL_STANDARD_BASE_URL=https://<workspace>--ollyuw-gemma4-standard-serve.modal.run
MODAL_TURBO_BASE_URL=https://<workspace>--ollyuw-gemma4-turboquant-serve.modal.run
MODAL_API_KEY=unused
MODAL_MODEL=google/gemma-4-26B-A4B-it

# ── LLM — DeepSeek (frontier path) ──────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Supabase (optional — leave blank to skip) ────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Backend server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
